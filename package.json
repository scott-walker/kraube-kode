{
  "name": "kraube-kode",
  "productName": "kraube-kode",
  "version": "1.0.0",
  "description": "Desktop GUI for Claude Code",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "node -e \"require('fs').rmSync('.vite/build', {recursive:true, force:true}); require('fs').mkdirSync('logs', {recursive:true})\" && electron-forge start 2>&1 | tee logs/main-$(date +%Y%m%d-%H%M%S).log",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "keywords": [],
  "author": {
    "name": "Scott Walker",
    "email": "scott@swlt.ru"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@scottwalker/kraube-konnektor": "^0.6.5",
    "@types/dompurify": "^3.0.5",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "electron-squirrel-startup": "^1.0.1",
    "highlight.js": "^11.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  }
}
